{
  "name": "@paperclipai/plugin-ruflo-bridge",
  "version": "1.0.0",
  "description": "Ruflo MCP Bridge Plugin for Paperclip - Integrates Ruflo multi-agent orchestration, memory management, and workflow automation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
