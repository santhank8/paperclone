<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for V8 / Node.js -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (needed by Node/Electron) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Network client (API calls, WebSocket connections) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network server (Express server listens on a port) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Allow child processes (spawning the server, embedded postgres) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
