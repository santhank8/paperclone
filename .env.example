# Paperclip + DeerFlow Agent Network
# Copy to .env and fill in your values.

# ── Paperclip ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# ── LLM API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Local models via vLLM ──────────────────────────────────────
# vLLM serves an OpenAI-compatible API with high throughput.
# Firecrawl (web search/fetch) is self-hosted — no API key needed.
# VLLM_BASE_URL=http://host.docker.internal:8000

# ── Vibe-Stack Backend Config ────────────────────────────────────────────
# Paperclip injects these into agent containers at startup so they can talk
# directly to LLM backends.  Each agent container is self-sufficient — no
# inference calls route through Paperclip.
# VIBE_BACKEND_HOST=http://host.docker.internal:8000/v1
# VIBE_FALLBACK_URLS=http://fallback1:8000/v1,http://fallback2:8000/v1
