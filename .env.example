# === PAPERCLIP SERVER CONFIGURATION ===

# Server Host & Port
HOST=0.0.0.0
PORT=3100

# UI Service
SERVE_UI=true

# Database Configuration (PostgreSQL)
# In production, use an external PostgreSQL instance
# DB_PASSWORD is REQUIRED — never use the default in production
DB_USER=paperclip
DB_PASSWORD=change-me-in-production
DB_NAME=paperclip
DATABASE_URL=postgres://paperclip:change-me-in-production@db:5432/paperclip

# Authentication Secret - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production

# Deployment Settings
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Public URL - Used for auth redirects and API references
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Node Environment
NODE_ENV=production

# Optional: Logging
LOG_LEVEL=info

# Optional: AWS S3 Configuration (if using S3 for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=paperclip-files

# Optional: Agent Adapters Configuration
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# CODEX_BASE_URL=
# OPENCLAW_BASE_URL=
# OLLAMA_BASE_URL=http://ollama:11434

# Optional: Plugin System
# PAPERCLIP_PLUGINS_ENABLED=true
# PAPERCLIP_WORKER_THREADS=4
