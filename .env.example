# Paperclip + DeerFlow Agent Network
# Copy to .env and fill in your values.

# ── Paperclip ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip
PORT=3100
SERVE_UI=true
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# ── LLM API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Local models via vLLM ──────────────────────────────────────
# vLLM serves an OpenAI-compatible API with high throughput.
# Firecrawl (web search/fetch) is self-hosted — no API key needed.
# VLLM_BASE_URL=http://host.docker.internal:8000
