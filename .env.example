DATABASE_URL=postgres://ironworks:ironworks@localhost:5432/ironworks
PORT=3100
SERVE_UI=false

# Required for Docker deployments
BETTER_AUTH_SECRET=your-auth-secret-here
IRONWORKS_PUBLIC_URL=http://localhost:3100

# For Docker production (docker-compose.production.yml)
# POSTGRES_PASSWORD=your-postgres-password

# LLM Provider API keys (set the ones you use)
