DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Optional: Cursor Cloud / Cursor CLI API key for Cursor-backed agents (e.g. CEO). Prefer agent adapter env or secrets in production.
# CURSOR_API_KEY=

# Optional: base URL agents use to call Paperclip (defaults from listen host/port). Set when agents must use 127.0.0.1 or a public URL.
# PAPERCLIP_API_URL=http://127.0.0.1:3101
