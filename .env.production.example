# =============================================================
# Paperclip Production Environment
# Copy this file to .env and fill in all required values.
# =============================================================

# ---- Docker Image ----
# Set by scripts/push-gcp.sh or scripts/push-aws.sh, or fill in manually.
IMAGE_URI=

# ---- Supabase PostgreSQL ----
# Session-mode pooler — used by the server at runtime (supports prepared statements).
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Direct connection — used only for Drizzle migrations at server startup.
# Format: postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres
DATABASE_DIRECT_URL=

# ---- Authentication ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Restrict sign-ups to specific email domains (comma-separated). Leave unset to allow all domains.
PAPERCLIP_AUTH_ALLOWED_EMAIL_DOMAINS=your-company.com

# ---- Domain / Public URL ----
# The fully-qualified domain name Caddy will serve (e.g. paperclip.example.com).
PAPERCLIP_DOMAIN=
# Must match the domain above (including https://).
PAPERCLIP_PUBLIC_URL=

# ---- Deployment Mode ----
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# ---- AI Provider API Keys ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Volume Ownership ----
# Set to the UID/GID of the user on the VM that owns the /paperclip data directory.
# Run `id -u` and `id -g` on the VM to find the correct values.
USER_UID=1000
USER_GID=1000
