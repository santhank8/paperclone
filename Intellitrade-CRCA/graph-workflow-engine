/**
 * Execute full trading analysis with Graph Workflow
 */
async function executeFullTradingAnalysis(marketData) {
  log('\n' + '═'.repeat(60));
  log('🔷 GRAPH WORKFLOW: Full Trading Analysis');
  log('═'.repeat(60));
  
  const workflow = createFullTradingWorkflow(marketData);
  
  try {
    const result = await executeGraphWorkflow(workflow, 600000); // 10min timeout
    
    if (result.status === 'success') {
      const decision = parseATLASDecision(result.outputs);
      
      log('\n📊 WORKFLOW RESULTS:');
      log(`   BTC: ${decision.btc.decision} @ ${decision.btc.confidence}%`);
      log(`   ETH: ${decision.eth.decision} @ ${decision.eth.confidence}%`);
      log(`   Risk: ${decision.riskLevel} | Size: ${decision.positionSizePct}%`);
      log(`   SL: ${decision.stopLossPct}% | TP: ${decision.takeProfitPct}%`);
      log(`   Reasoning: ${decision.reasoning}`);
      
      return {
        success: true,
        decision,
        outputs: result.outputs,
        usage: result.usage,
        jobId: result.job_id
      };
    } else {
      throw new Error(`Workflow failed: ${result.status}`);
    }
  } catch (error) {
    log(`❌ Workflow error: ${error.message}`);
    return { success: false, error: error.message };
  }
}

/**
 * Execute quick scalping analysis
 */
async function executeScalpingAnalysis(marketData) {
  log('\n⚡ GRAPH WORKFLOW: Scalping Analysis');
  
  const workflow = createScalpingWorkflow(marketData);
  
  try {
    const result = await executeGraphWorkflow(workflow, 120000); // 2min timeout
    
    if (result.status === 'success') {
      const scalpOutput = result.outputs.ScalpDecision || '';
      
      const decision = scalpOutput.match(/DECISION:\s*(\w+)/i)?.[1] || 'SKIP';
      const confidence = parseInt(scalpOutput.match(/CONFIDENCE:\s*(\d+)/i)?.[1]) || 50;
      const entryNow = scalpOutput.match(/ENTRY_NOW:\s*(YES|NO)/i)?.[1] === 'YES';
      const targetPct = parseFloat(scalpOutput.match(/TARGET_PCT:\s*([\d.]+)/i)?.[1]) || 1.5;
      const stopPct = parseFloat(scalpOutput.match(/STOP_PCT:\s*([\d.]+)/i)?.[1]) || 0.8;
      
      log(`   Decision: ${decision} @ ${confidence}% | Entry: ${entryNow ? 'NOW' : 'WAIT'}`);
      
      return {
        success: true,
        decision,
        confidence,
        entryNow,
        targetPct,
        stopPct,
        jobId: result.job_id
      };
    }
  } catch (error) {
    log(`❌ Scalp workflow error: ${error.message}`);
    return { success: false, error: error.message };
  }
}

/**
 * Execute risk assessment workflow
 */
async function executeRiskAssessment(positionData) {
  log('\n🛡️ GRAPH WORKFLOW: Risk Assessment');
  
  const workflow = createRiskWorkflow(positionData);
  
  try {
    const result = await executeGraphWorkflow(workflow, 120000);
    
    if (result.status === 'success') {
      const riskOutput = result.outputs.RiskDecision || '';
      
      const approved = riskOutput.match(/RISK_APPROVED:\s*(YES|NO)/i)?.[1] === 'YES';
      const riskScore = parseInt(riskOutput.match(/RISK_SCORE:\s*(\d+)/i)?.[1]) || 5;
      const maxSize = parseFloat(riskOutput.match(/MAX_POSITION_SIZE:\s*\$?([\d.]+)/i)?.[1]) || 100;
      
      log(`   Approved: ${approved ? 'YES' : 'NO'} | Risk Score: ${riskScore}/10`);
      
      return {
