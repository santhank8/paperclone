const https = require('https');
const fs = require('fs');
const path = require('path');

const BASE_URL = 'api.swarms.world';
const LOG_FILE = '/home/ubuntu/intellitrade/logs/graph-workflow.log';

// Ensure logs directory exists
const logsDir = path.dirname(LOG_FILE);
if (!fs.existsSync(logsDir)) fs.mkdirSync(logsDir, { recursive: true });

function log(msg) {
  const ts = new Date().toISOString();
  const line = `[${ts}] ${msg}`;
  console.log(line);
  try { fs.appendFileSync(LOG_FILE, line + '\n'); } catch(e) {}
}

/**
 * Get SwarmsAI API key
 */
function getApiKey() {
  if (process.env.SWARMS_API_KEY) return process.env.SWARMS_API_KEY;
  
  const secretsPath = path.join(process.env.HOME, '.config/abacusai_auth_secrets.json');
  if (fs.existsSync(secretsPath)) {
    const secrets = JSON.parse(fs.readFileSync(secretsPath, 'utf8'));
    if (secrets.swarmsai?.secrets?.api_key?.value) {
      return secrets.swarmsai.secrets.api_key.value;
    }
  }
  
  const envPath = '/home/ubuntu/intellitrade/nextjs_space/.env';
  if (fs.existsSync(envPath)) {
    const envContent = fs.readFileSync(envPath, 'utf8');
    const match = envContent.match(/SWARMS_API_KEY=(.+)/);
    if (match) return match[1].trim();
  }
  
  throw new Error('SWARMS_API_KEY not found');
}

/**
 * Make Graph Workflow API request
 */
function executeGraphWorkflow(workflowInput, timeout = 300000) {
  return new Promise((resolve, reject) => {
    const apiKey = getApiKey();
    const postData = JSON.stringify(workflowInput);
    
    const options = {
      hostname: BASE_URL,
      path: '/v1/graph-workflow/completions',
      method: 'POST',
      headers: {
        'x-api-key': apiKey,
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(postData)
      }
    };
    
    log(`📊 Executing Graph Workflow: ${workflowInput.name}`);
    log(`   Agents: ${workflowInput.agents.map(a => a.agent_name).join(' → ')}`);
    
    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        try {
          const result = JSON.parse(data);
          if (res.statusCode === 200) {
            log(`✅ Workflow complete: ${result.job_id}`);
            log(`   Status: ${result.status}`);
            if (result.usage) {
              log(`   Tokens: ${result.usage.total_tokens} | Cost: $${result.usage.token_cost?.toFixed(4)}`);
            }
            resolve(result);
          } else {
            log(`❌ Workflow error: ${res.statusCode}`);
            log(`   Response: ${data.substring(0, 200)}`);
            reject(new Error(`API Error ${res.statusCode}: ${data}`));
          }
        } catch (e) {
          reject(e);
        }
      });
    });
    
    req.on('error', reject);
    req.setTimeout(timeout, () => {
      req.destroy();
      reject(new Error('Graph Workflow timeout'));
    });
    
    req.write(postData);
    req.end();
  });
}

