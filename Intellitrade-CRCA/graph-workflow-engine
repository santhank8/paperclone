/**
 * Parse ATLAS decision from workflow output
 */
function parseATLASDecision(outputs) {
  const atlasOutput = outputs.ATLASChief || outputs.ScalpDecision || '';
  
  const parseField = (text, field) => {
    const regex = new RegExp(`${field}:\\s*([^\\n]+)`, 'i');
    const match = text.match(regex);
    return match ? match[1].trim() : null;
  };
  
  return {
    btc: {
      decision: parseField(atlasOutput, 'BTC_DECISION') || 'HOLD',
      confidence: parseInt(parseField(atlasOutput, 'BTC_CONFIDENCE')) || 50
    },
    eth: {
      decision: parseField(atlasOutput, 'ETH_DECISION') || 'HOLD',
      confidence: parseInt(parseField(atlasOutput, 'ETH_CONFIDENCE')) || 50
    },
    riskLevel: parseField(atlasOutput, 'RISK_LEVEL') || 'MEDIUM',
    positionSizePct: parseFloat(parseField(atlasOutput, 'POSITION_SIZE_PCT')) || 10,
    stopLossPct: parseFloat(parseField(atlasOutput, 'STOP_LOSS_PCT')) || 2.0,
    takeProfitPct: parseFloat(parseField(atlasOutput, 'TAKE_PROFIT_PCT')) || 3.0,
    reasoning: parseField(atlasOutput, 'REASONING') || 'No reasoning provided',
    raw: atlasOutput
  };
}

/**
 * Get agent outputs summary
 */
function summarizeWorkflowOutputs(outputs) {
  const summary = {};
  for (const [agent, output] of Object.entries(outputs)) {
    if (typeof output === 'string') {
      summary[agent] = output.substring(0, 200) + (output.length > 200 ? '...' : '');
    }
  }
  return summary;
}

