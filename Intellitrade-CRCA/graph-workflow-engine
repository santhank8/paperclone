        approved,
        riskScore,
        maxPositionSize: maxSize,
        concerns: result.outputs.DevilsAdvocate?.substring(0, 300),
        jobId: result.job_id
      };
    }
  } catch (error) {
    log(`❌ Risk workflow error: ${error.message}`);
    return { success: false, error: error.message };
  }
}

