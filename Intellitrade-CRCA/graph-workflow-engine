/**
 * Full Trading Analysis Workflow
 * 3 collectors → 3 analysts → 2 validators → 1 CEO decision
 */
function createFullTradingWorkflow(marketData, task) {
  const agents = [
    // Layer 1: Data Collectors
    TRADING_AGENTS.MarketDataCollector,
    TRADING_AGENTS.SentimentCollector,
    TRADING_AGENTS.TechnicalCollector,
    // Layer 2: Analysts
    TRADING_AGENTS.TrendAnalyst,
    TRADING_AGENTS.RiskAnalyst,
    TRADING_AGENTS.MomentumAnalyst,
    // Layer 3: Validators
    TRADING_AGENTS.SignalValidator,
    TRADING_AGENTS.DevilsAdvocate,
    // Layer 4: Decision
    TRADING_AGENTS.ATLASChief
  ];
  
  const edges = [
    // Layer 1 → Layer 2 (All collectors feed all analysts)
    { source: 'MarketDataCollector', target: 'TrendAnalyst' },
    { source: 'MarketDataCollector', target: 'RiskAnalyst' },
    { source: 'MarketDataCollector', target: 'MomentumAnalyst' },
    { source: 'SentimentCollector', target: 'TrendAnalyst' },
    { source: 'SentimentCollector', target: 'RiskAnalyst' },
    { source: 'SentimentCollector', target: 'MomentumAnalyst' },
    { source: 'TechnicalCollector', target: 'TrendAnalyst' },
    { source: 'TechnicalCollector', target: 'RiskAnalyst' },
    { source: 'TechnicalCollector', target: 'MomentumAnalyst' },
    // Layer 2 → Layer 3 (All analysts feed validators)
    { source: 'TrendAnalyst', target: 'SignalValidator' },
    { source: 'RiskAnalyst', target: 'SignalValidator' },
    { source: 'MomentumAnalyst', target: 'SignalValidator' },
    { source: 'TrendAnalyst', target: 'DevilsAdvocate' },
    { source: 'RiskAnalyst', target: 'DevilsAdvocate' },
    { source: 'MomentumAnalyst', target: 'DevilsAdvocate' },
    // Layer 3 → Layer 4 (Validators feed CEO)
    { source: 'SignalValidator', target: 'ATLASChief' },
    { source: 'DevilsAdvocate', target: 'ATLASChief' }
  ];
  
  const fullTask = `
=== MARKET DATA ===
${JSON.stringify(marketData, null, 2)}

=== TRADING TASK ===
${task || 'Analyze BTC and ETH for optimal trading positions. Provide LONG/SHORT/HOLD decisions with confidence levels.'}
`;
  
  return {
    name: 'Intellitrade-Full-Trading-Workflow',
    description: 'Multi-layer parallel workflow for comprehensive trading analysis',
    agents,
    edges,
    entry_points: ['MarketDataCollector', 'SentimentCollector', 'TechnicalCollector'],
    end_points: ['ATLASChief'],
    max_loops: 1,
    task: fullTask,
    auto_compile: true,
    verbose: false
  };
}

