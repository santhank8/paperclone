const https = require('https');
const fs = require('fs');
const path = require('path');

const BASE_URL = 'api.swarms.world';
const LOG_FILE = '/home/ubuntu/intellitrade/logs/risk-debate.log';

/**
 * Logging utility
 */
function log(message) {
    const timestamp = new Date().toISOString();
    const logLine = `[${timestamp}] ${message}`;
    console.log(logLine);
    try {
        fs.appendFileSync(LOG_FILE, logLine + '\n');
    } catch (e) {}
}

/**
 * Get SwarmsAI API key
 */
function getApiKey() {
    if (process.env.SWARMS_API_KEY) {
        return process.env.SWARMS_API_KEY;
    }
    
    const secretsPath = path.join(process.env.HOME, '.config/abacusai_auth_secrets.json');
    if (fs.existsSync(secretsPath)) {
        const secrets = JSON.parse(fs.readFileSync(secretsPath, 'utf8'));
        if (secrets.swarmsai?.secrets?.api_key?.value) {
            return secrets.swarmsai.secrets.api_key.value;
        }
    }
    
    const envPath = '/home/ubuntu/intellitrade/nextjs_space/.env';
    if (fs.existsSync(envPath)) {
        const envContent = fs.readFileSync(envPath, 'utf8');
        const match = envContent.match(/SWARMS_API_KEY=(.+)/);
        if (match) return match[1].trim();
    }
    
    throw new Error('SWARMS_API_KEY not found');
}

/**
 * Make API request to Swarms.ai
 */
function makeRequest(method, endpoint, data = null) {
    return new Promise((resolve, reject) => {
        const apiKey = getApiKey();
        
        const options = {
            hostname: BASE_URL,
            port: 443,
            path: endpoint,
            method: method,
            headers: {
                'x-api-key': apiKey,
                'Content-Type': 'application/json'
            },
            timeout: 120000
        };
        
        const req = https.request(options, (res) => {
            let body = '';
            res.on('data', chunk => body += chunk);
            res.on('end', () => {
                try {
                    const result = JSON.parse(body);
                    if (res.statusCode >= 200 && res.statusCode < 300) {
                        resolve(result);
                    } else {
                        reject(new Error(`API Error ${res.statusCode}: ${JSON.stringify(result)}`));
                    }
                } catch (e) {
                    reject(new Error(`Parse error: ${body}`));
                }
            });
        });
        
        req.on('error', reject);
        req.on('timeout', () => {
            req.destroy();
            reject(new Error('Request timeout'));
        });
        
        if (data) {
            req.write(JSON.stringify(data));
        }
        
        req.end();
    });
}

