/**
 * Execute a trading risk debate using DebateWithJudge architecture
 * 
 * @param {Object} config - Debate configuration
 * @param {string} config.symbol - Trading symbol (BTC, ETH)
 * @param {string} config.proposedDirection - LONG or SHORT
 * @param {number} config.currentPrice - Current price
 * @param {Object} config.marketData - Market intelligence data
 * @param {Object} config.liquidationData - Liquidation heatmap data
 * @param {number} config.maxLoops - Number of refinement rounds (default: 1)
 * @returns {Promise<Object>} Debate result with verdict
 */
async function executeRiskDebate(config) {
    const {
        symbol = 'BTC',
        proposedDirection = 'LONG',
        currentPrice,
        marketData = {},
        liquidationData = {},
        technicalData = {},
        maxLoops = 1
    } = config;
    
    log(`\n${'═'.repeat(60)}`);
    log(`⚖️ RISK DEBATE ENGINE - ${symbol} ${proposedDirection}`);
    log(`${'═'.repeat(60)}`);
    
    // Construct the debate task
    const debateTask = `
TRADING PROPOSAL UNDER DEBATE:
- Symbol: ${symbol}USDT
- Proposed Direction: ${proposedDirection}
- Current Price: $${currentPrice?.toLocaleString() || 'N/A'}

MARKET CONTEXT:
- Fear & Greed Index: ${marketData.fearGreed?.value || 'N/A'} (${marketData.fearGreed?.classification || 'N/A'})
- MACD: ${technicalData.macd || 'N/A'}
- SMA Structure: ${technicalData.smaStructure || 'N/A'}
- Market Bias: ${marketData.bias || 'NEUTRAL'} @ ${marketData.confidence || 0}%

LIQUIDATION HEATMAP:
- Signal: ${liquidationData.signal || 'NEUTRAL'}
- Confidence: ${liquidationData.confidence || 50}%
- Reason: ${liquidationData.reason || 'No data'}
- Long Liq Below: $${(liquidationData.longLiqBelow / 1e6)?.toFixed(1) || 0}M
- Short Liq Above: $${(liquidationData.shortLiqAbove / 1e6)?.toFixed(1) || 0}M

KEY LEVELS:
- Resistance: $${technicalData.resistance || 'N/A'}
- Support: $${technicalData.support || 'N/A'}

DEBATE QUESTION:
Should Intellitrade agents execute a ${proposedDirection} position on ${symbol} at $${currentPrice?.toLocaleString() || 'current price'}?

Consider: Risk/reward ratio, liquidation risks, market regime, technical setup, and position sizing.
`;

    log(`📋 Debate Task Constructed`);
    log(`📊 ${symbol} @ $${currentPrice} | Proposed: ${proposedDirection}`);
    
    try {
        const payload = {
            name: `${symbol} Risk Debate`,
            description: `Structured risk assessment debate for ${symbol} ${proposedDirection} position`,
            swarm_type: 'DebateWithJudge',
            task: debateTask,
            agents: [
                TRADING_DEBATE_AGENTS.bullCase,
                TRADING_DEBATE_AGENTS.bearCase,
                TRADING_DEBATE_AGENTS.judge
            ],
            max_loops: maxLoops
        };
        
        log(`🤖 Executing DebateWithJudge swarm...`);
        const startTime = Date.now();
        
        const result = await makeRequest('POST', '/v1/swarm/completions', payload);
        
        const executionTime = ((Date.now() - startTime) / 1000).toFixed(1);
        log(`✅ Debate completed in ${executionTime}s`);
        
        // Parse the debate output
        const parsedResult = parseDebateOutput(result, symbol, proposedDirection);
        
        log(`\n📊 DEBATE SUMMARY`);
        log(`─────────────────────────────────────`);
        log(`🎯 Verdict: ${parsedResult.verdict}`);
        log(`📈 Direction: ${parsedResult.direction}`);
        log(`💯 Confidence: ${parsedResult.confidence}%`);
        log(`⚠️ Risk Score: ${parsedResult.riskScore}/10`);
        log(`🛡️ VaultKeeper: ${parsedResult.riskScore > 7 ? 'VETOED ❌' : 'APPROVED ✅'}`);
        
        if (parsedResult.entry) {
            log(`\n📍 Trade Levels:`);
            log(`   Entry: $${parsedResult.entry}`);
            log(`   Stop Loss: $${parsedResult.stopLoss}`);
            log(`   Take Profit: $${parsedResult.takeProfit}`);
            log(`   Position Size: ${parsedResult.positionSize}%`);
        }
        
        return {
            success: true,
            symbol,
            proposedDirection,
            currentPrice,
            ...parsedResult,
            rawOutput: result.output,
            executionTime: parseFloat(executionTime),
            usage: result.usage
        };
        
    } catch (error) {
        log(`❌ Debate Error: ${error.message}`);
        return {
            success: false,
            error: error.message,
            symbol,
            proposedDirection,
            verdict: 'WAIT',
            riskScore: 10,
            confidence: 0,
            reason: 'Debate failed - defaulting to conservative stance'
        };
    }
}

/**
 * Parse debate output to extract actionable trading signals
 */
function parseDebateOutput(result, symbol, proposedDirection) {
    const output = {
        verdict: 'WAIT',
        direction: proposedDirection,
        confidence: 50,
        riskScore: 5,
        entry: null,
        stopLoss: null,
        takeProfit: null,
        positionSize: 2,
        bullArguments: '',
        bearArguments: '',
        judgeReasoning: '',
        vetoed: false
    };
    
    if (!result.output || !Array.isArray(result.output)) {
        return output;
    }
    
    // Extract each agent's response
    for (const item of result.output) {
        const role = item.role?.toLowerCase() || '';
        const content = item.content || '';
        
        if (role.includes('bull') || role.includes('pro') || role.includes('titan')) {
            output.bullArguments = content;
        } else if (role.includes('bear') || role.includes('con') || role.includes('hydra')) {
            output.bearArguments = content;
        } else if (role.includes('judge') || role.includes('atlas')) {
            output.judgeReasoning = content;
            
            // Parse verdict
            if (content.includes('EXECUTE') || content.includes('execute')) {
                output.verdict = 'EXECUTE';
            } else if (content.includes('REJECT') || content.includes('reject')) {
                output.verdict = 'REJECT';
            } else {
                output.verdict = 'WAIT';
            }
            
            // Parse direction
            if (content.includes('LONG')) output.direction = 'LONG';
            else if (content.includes('SHORT')) output.direction = 'SHORT';
            else if (content.includes('NEUTRAL')) output.direction = 'NEUTRAL';
            
            // Parse confidence (look for patterns like "85%" or "Confidence: 85")
            const confMatch = content.match(/(?:confidence|CONFIDENCE)[:\s]*([0-9]+)/i) ||
                              content.match(/([0-9]+)\s*%\s*(?:confidence|confident)/i);
            if (confMatch) {
                output.confidence = parseInt(confMatch[1]);
            }
            
            // Parse risk score (look for patterns like "7/10" or "Risk: 7")
            const riskMatch = content.match(/(?:risk|RISK)\s*(?:score|SCORE)?[:\s]*([0-9]+)/i) ||
                              content.match(/([0-9]+)\s*\/\s*10/i);
            if (riskMatch) {
                output.riskScore = parseInt(riskMatch[1]);
            }
            
            // Parse price levels
            const entryMatch = content.match(/(?:entry|Entry)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
            const slMatch = content.match(/(?:stop\s*loss|SL)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
            const tpMatch = content.match(/(?:take\s*profit|TP)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
            const sizeMatch = content.match(/(?:position\s*size|size)[:\s]*([0-9]+(?:\.[0-9]+)?)\s*%/i);
            
            if (entryMatch) output.entry = parseFloat(entryMatch[1].replace(/,/g, ''));
            if (slMatch) output.stopLoss = parseFloat(slMatch[1].replace(/,/g, ''));
            if (tpMatch) output.takeProfit = parseFloat(tpMatch[1].replace(/,/g, ''));
            if (sizeMatch) output.positionSize = parseFloat(sizeMatch[1]);
        }
    }
    
    // Apply VaultKeeper veto rule
    if (output.riskScore > 7) {
        output.vetoed = true;
        output.verdict = 'REJECT';
    }
    
    return output;
}

/**
 * Execute multi-asset risk debate (BTC + ETH simultaneously)
 */
async function executeMultiAssetDebate(assets) {
    log(`\n${'═'.repeat(60)}`);
    log(`⚖️ MULTI-ASSET RISK DEBATE`);
    log(`${'═'.repeat(60)}`);
    
    const results = {};
    
    for (const asset of assets) {
        results[asset.symbol] = await executeRiskDebate(asset);
        // Small delay between debates to avoid rate limiting
        await new Promise(r => setTimeout(r, 1000));
    }
    
    return results;
}

/**
 * Quick risk assessment without full debate (for time-critical decisions)
 */
async function quickRiskAssessment(config) {
    const { symbol, direction, currentPrice, riskFactors = {} } = config;
    
    const task = `Quick risk assessment for ${symbol} ${direction} at $${currentPrice}.
Factors: ${JSON.stringify(riskFactors)}
Provide: RISK_SCORE (1-10), PROCEED (yes/no), ONE_LINE_REASON.`;
    
    try {
        const result = await makeRequest('POST', '/v1/agent/completions', {
            agent_config: {
                agent_name: 'VaultKeeper',
                system_prompt: 'You are VaultKeeper, Intellitrade risk manager. Provide quick risk scores (1-10). Be conservative.',
                model_name: 'gpt-4o-mini',
                max_loops: 1
            },
            task,
            max_tokens: 200
        });
        
        const content = result.output || result.response || '';
        const scoreMatch = content.match(/([0-9]+)/); 
        const score = scoreMatch ? parseInt(scoreMatch[1]) : 5;
        const proceed = !content.toLowerCase().includes('no') && score <= 7;
        
        return {
            success: true,
            riskScore: Math.min(score, 10),
            proceed,
            reason: content.substring(0, 200)
        };
    } catch (error) {
        return {
            success: false,
            riskScore: 10,
            proceed: false,
            reason: error.message
        };
    }
}

