/**
 * Detect current market regime from data
 */
function detectMarketRegime(marketData) {
    const {
        fearGreed = 50,
        volatility = 'medium',
        trend = 'neutral',
        liquidationImbalance = 0,
        priceChange24h = 0
    } = marketData;
    
    // High liquidation imbalance = squeeze potential
    if (Math.abs(liquidationImbalance) > 1.5) {
        return 'SQUEEZE_POTENTIAL';
    }
    
    // High volatility
    if (volatility === 'high' || Math.abs(priceChange24h) > 5) {
        return 'HIGH_VOLATILITY';
    }
    
    // Trending markets
    if (trend === 'bullish' && priceChange24h > 2) {
        return 'TRENDING_BULL';
    }
    if (trend === 'bearish' && priceChange24h < -2) {
        return 'TRENDING_BEAR';
    }
    
    // Low volatility
    if (volatility === 'low' && Math.abs(priceChange24h) < 1) {
        return 'LOW_VOLATILITY';
    }
    
    // Default to ranging
    return 'RANGING';
}

/**
 * Build agent team based on market regime
 */
function buildAgentTeam(regime, customAgents = null) {
    const regimeConfig = MARKET_REGIMES[regime] || MARKET_REGIMES.RANGING;
    
    const agents = [];
    
    // Add primary agents
    for (const agentKey of regimeConfig.primaryAgents) {
        if (TRADING_AGENT_POOL[agentKey]) {
            const agent = { ...TRADING_AGENT_POOL[agentKey] };
            delete agent.skills; // Remove internal metadata
            agents.push(agent);
        }
    }
    
    // Add support agents
    for (const agentKey of regimeConfig.supportAgents) {
        if (TRADING_AGENT_POOL[agentKey]) {
            const agent = { ...TRADING_AGENT_POOL[agentKey] };
            delete agent.skills;
            agents.push(agent);
        }
    }
    
    // Override with custom agents if provided
    if (customAgents && customAgents.length > 0) {
        return customAgents;
    }
    
    return agents;
}

/**
 * Execute AgentRearrange swarm for trading analysis
 * 
 * @param {Object} config - Rearrange configuration
 * @returns {Promise<Object>} Rearranged agent execution result
 */
async function executeAgentRearrange(config) {
    const {
        name = 'Adaptive Trading Analysis',
        description = 'Dynamic agent role assignment based on market conditions',
        task,
        marketData = {},
        forceRegime = null,
        customAgents = null,
        maxLoops = 1
    } = config;
    
    // Detect market regime
    const regime = forceRegime || detectMarketRegime(marketData);
    const regimeInfo = MARKET_REGIMES[regime];
    
    log(`\n${'═'.repeat(60)}`);
    log(`🔄 AGENT REARRANGE ENGINE`);
    log(`${'═'.repeat(60)}`);
    log(`📊 Detected Regime: ${regime}`);
    log(`📝 Description: ${regimeInfo?.description || 'Custom'}`);
    
    // Build optimized agent team
    const agents = buildAgentTeam(regime, customAgents);
    
    log(`\n🤖 ASSIGNED AGENTS (${agents.length}):`);
    agents.forEach((agent, i) => {
        log(`   ${i+1}. ${agent.agent_name} - ${agent.description}`);
    });
    
    // Construct the rearrange task
    const fullTask = `
MARKET REGIME: ${regime}
${regimeInfo?.description || ''}

MARKET CONTEXT:
${JSON.stringify(marketData, null, 2)}

TASK:
${task}

INSTRUCTIONS:
- Agents may be reassigned roles mid-task based on emerging information
- ATLAS CEO coordinates and can delegate dynamically
- Each agent should contribute based on their specialty
- Final output should include: SIGNAL, CONFIDENCE, RISK_LEVEL, AGENT_CONTRIBUTIONS
`;
    
    try {
        // Build rearrange_flow from agent names
        // Format: agent1 -> agent2 -> agent3
        const agentNames = agents.map(a => a.agent_name);
        const rearrangeFlow = agentNames.join(' -> ');
        
        const payload = {
            name,
            description: `${description} | Regime: ${regime}`,
            swarm_type: 'AgentRearrange',
            task: fullTask,
            agents,
            rearrange_flow: rearrangeFlow,
            max_loops: maxLoops
        };
        
        log(`\n🔗 Rearrange Flow: ${rearrangeFlow}`);
        log(`🚀 Executing AgentRearrange swarm...`);
        const startTime = Date.now();
        
        const result = await makeRequest('POST', '/v1/swarm/completions', payload);
        
        const executionTime = ((Date.now() - startTime) / 1000).toFixed(1);
        log(`✅ Rearrange completed in ${executionTime}s`);
        
        // Parse and structure the result
        const parsedResult = parseRearrangeOutput(result, regime);
        
        log(`\n📊 REARRANGE SUMMARY`);
        log(`${'─'.repeat(40)}`);
        log(`🎯 Signal: ${parsedResult.signal}`);
        log(`💯 Confidence: ${parsedResult.confidence}%`);
        log(`⚠️ Risk Level: ${parsedResult.riskLevel}/10`);
        log(`🔄 Agents Used: ${parsedResult.agentsUsed}`);
        
        return {
            success: true,
            regime,
            regimeDescription: regimeInfo?.description,
            ...parsedResult,
            rawOutput: result.output,
            executionTime: parseFloat(executionTime),
            usage: result.usage
        };
        
    } catch (error) {
        log(`❌ Rearrange Error: ${error.message}`);
        return {
            success: false,
            error: error.message,
            regime,
            signal: 'NEUTRAL',
            confidence: 0,
            riskLevel: 10
        };
    }
}

/**
 * Parse AgentRearrange output into structured format
 */
function parseRearrangeOutput(result, regime) {
    const output = {
        signal: 'NEUTRAL',
        direction: 'HOLD',
        confidence: 50,
        riskLevel: 5,
        entry: null,
        stopLoss: null,
        takeProfit: null,
        positionSize: 2,
        agentContributions: [],
        agentsUsed: 0,
        rearrangementNotes: ''
    };
    
    if (!result.output || !Array.isArray(result.output)) {
        return output;
    }
    
    output.agentsUsed = result.output.length;
    
    // Collect all agent outputs
    let combinedText = '';
    for (const item of result.output) {
        const role = item.role || 'Unknown';
        const content = item.content || '';
        
        output.agentContributions.push({
            agent: role,
            summary: content.substring(0, 500)
        });
        
        combinedText += content + '\n';
    }
    
    // Parse signal from combined output
    if (combinedText.includes('LONG') || combinedText.includes('BUY')) {
        output.signal = 'LONG';
        output.direction = 'LONG';
    } else if (combinedText.includes('SHORT') || combinedText.includes('SELL')) {
        output.signal = 'SHORT';
        output.direction = 'SHORT';
    } else if (combinedText.includes('WAIT') || combinedText.includes('HOLD')) {
        output.signal = 'WAIT';
        output.direction = 'HOLD';
    }
    
    // Parse confidence
    const confMatch = combinedText.match(/(?:confidence|CONFIDENCE)[:\s]*([0-9]+)/i) ||
                      combinedText.match(/([0-9]+)\s*%\s*(?:confidence|confident)/i);
    if (confMatch) {
        output.confidence = Math.min(parseInt(confMatch[1]), 100);
    }
    
    // Parse risk level
    const riskMatch = combinedText.match(/(?:risk|RISK)\s*(?:level|score)?[:\s]*([0-9]+)/i) ||
                      combinedText.match(/([0-9]+)\s*\/\s*10/i);
    if (riskMatch) {
        output.riskLevel = Math.min(parseInt(riskMatch[1]), 10);
    }
    
    // Parse price levels
    const entryMatch = combinedText.match(/(?:entry|Entry)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
    const slMatch = combinedText.match(/(?:stop\s*loss|SL)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
    const tpMatch = combinedText.match(/(?:take\s*profit|TP|target)[:\s]*\$?([0-9,]+(?:\.[0-9]+)?)/i);
    
    if (entryMatch) output.entry = parseFloat(entryMatch[1].replace(/,/g, ''));
    if (slMatch) output.stopLoss = parseFloat(slMatch[1].replace(/,/g, ''));
    if (tpMatch) output.takeProfit = parseFloat(tpMatch[1].replace(/,/g, ''));
    
    // Check for rearrangement notes
    if (result.agent_rearrangement) {
        output.rearrangementNotes = result.agent_rearrangement;
    }
    
    return output;
}

