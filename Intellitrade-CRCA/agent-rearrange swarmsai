        'scalp_range': 'RANGING',
        'crisis_mode': 'HIGH_VOLATILITY',
        'wait_breakout': 'LOW_VOLATILITY',
        'hunt_squeeze': 'SQUEEZE_POTENTIAL'
    };
    
    const regime = commandMap[command] || detectMarketRegime(marketData);
    
    return executeAgentRearrange({
        name: `ATLAS ${command.toUpperCase()} Operation`,
        task: `Execute ${command} strategy with optimal agent configuration`,
        marketData,
        forceRegime: regime
    });
}

