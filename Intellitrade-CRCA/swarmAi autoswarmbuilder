def main():
    parser = argparse.ArgumentParser(description="AutoSwarm Trading Strategy Manager")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # python auto_swarm_builder.py weekly
    weekly_parser = subparsers.add_parser("weekly", help="Run weekly strategy evolution")

    # python auto_swarm_builder.py market crash
    market_parser = subparsers.add_parser("market", help="Generate response to market condition")
    market_parser.add_argument("condition", choices=["crash", "rally", "high-volatility", "low-volatility"])

    # python auto_swarm_builder.py experiment "Name" "Hypothesis" --deploy
    exp_parser = subparsers.add_parser("experiment", help="Test experimental architecture")
    exp_parser.add_argument("name", help="Experiment short name")
    exp_parser.add_argument("hypothesis", help="Short description of the hypothesis")
    exp_parser.add_argument("--deploy", action="store_true", help="Deploy to active strategy")

    # python auto_swarm_builder.py status
    subparsers.add_parser("status", help="Show currently active strategy")

    args = parser.parse_args()

    builder = AutoSwarmBuilder()

    if args.command == "weekly":
        task = weekly_strategy_evolution()
        config = builder.run(task)
        archive_current_strategy()
        save_active_strategy(config)
        print("Weekly strategy evolution completed and deployed.")

    elif args.command == "market":
        task = market_condition_response(args.condition)
        config = builder.run(task)
        archive_current_strategy()
        save_active_strategy(config)
        print(f"Market condition response ({args.condition}) deployed.")

    elif args.command == "experiment":
        task = experimental_architecture(args.name, args.hypothesis)
        config = builder.run(task)
        if args.deploy:
            archive_current_strategy()
            save_active_strategy(config)
            print(f"Experiment '{args.name}' deployed to production.")
        else:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            path = Path(f"experiments/{timestamp}_{args.name}.json")
            path.parent.mkdir(exist_ok=True)
            path.write_text(json.dumps(config, indent=2))
            print(f"Experiment saved to: {path}")

    elif args.command == "status":
        try:
            active = json.loads(Path("config/active_strategy.json").read_text())
            print(json.dumps(active, indent=2))
        except FileNotFoundError:
            print("No active strategy deployed yet.")
if __name__ == "__main__":
    main()

