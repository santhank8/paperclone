from datetime import datetime
from pathlib import Path
import json
import shutil
CONFIG_DIR = Path("config")
ACTIVE_PATH = CONFIG_DIR / "active_strategy.json"
HISTORY_DIR = CONFIG_DIR / "strategy_history"
def archive_current_strategy() -> None:
    """Move current active strategy to history folder with timestamp"""
    HISTORY_DIR.mkdir(parents=True, exist_ok=True)

    if not ACTIVE_PATH.exists():
        return

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    dest = HISTORY_DIR / f"strategy_{timestamp}.json"
    shutil.copy2(ACTIVE_PATH, dest)
    print(f"Previous strategy archived → {dest.name}")
def save_active_strategy(config: dict) -> None:
    """Save new strategy as the active one"""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    ACTIVE_PATH.write_text(json.dumps(config, indent=2))
    print(f"Active strategy updated → {ACTIVE_PATH}")

