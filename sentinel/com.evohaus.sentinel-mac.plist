<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.evohaus.sentinel-mac</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/evohaus/sentinel-scripts/macos-healthcheck.sh</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>SENTINEL_WEBHOOK</key>
		<string>https://nail.n8n.evohaus.org/webhook/sentinel-alert</string>
		<key>SENTINEL_MACHINE</key>
		<string>m4-mac-mini</string>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
	</dict>
	<key>StartInterval</key>
	<integer>1800</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/Users/evohaus/sentinel-logs/launchagent-stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/evohaus/sentinel-logs/launchagent-stderr.log</string>
</dict>
</plist>
