# ============================================================
# Raava Dashboard - Production Docker Compose Environment
# Copy this file to .env and fill in values before deploying
# ============================================================

# Required: Database password for the raava PostgreSQL user
DB_PASSWORD=changeme

# Required: Secret key for BetterAuth session signing (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=changeme

# Required: Public URL where the dashboard will be accessible
PUBLIC_URL=https://demo.raava.io

# FleetOS API URL (default assumes FleetOS runs on the Docker host)
FLEETOS_API_URL=http://host.docker.internal:8400

# SSL / Certbot configuration
DOMAIN=demo.raava.io
EMAIL=admin@raava.io

# Deployment mode: authenticated | local_trusted
DEPLOYMENT_MODE=authenticated

# Deployment exposure: private | public
DEPLOYMENT_EXPOSURE=private
