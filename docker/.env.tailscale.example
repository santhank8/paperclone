# =============================================================================
# Paperclip — Tailscale VPS Deployment
# =============================================================================
# Copy this file to docker/.env and fill in the values before running:
#   docker compose up -d
#
# Prerequisites:
#   1. Install Tailscale on the VPS:  curl -fsSL https://tailscale.com/install.sh | sh
#   2. Authenticate:                  sudo tailscale up
#   3. Get your Tailscale IP:         tailscale ip -4
#   4. Block public access:           sudo ufw allow in on tailscale0 to any port 3100
#                                     sudo ufw deny 3100
#                                     sudo ufw enable
# =============================================================================

# --- Tailscale Network ---
# Your Tailscale IP (run: tailscale ip -4) or MagicDNS name
# Examples:
#   PAPERCLIP_PUBLIC_URL=http://100.64.0.5:3100
#   PAPERCLIP_PUBLIC_URL=https://paperclip-vps.tailnet-name.ts.net
PAPERCLIP_PUBLIC_URL=http://TAILSCALE_IP:3100

# Comma-separated list of additional hostnames to allow (Tailscale IP + MagicDNS)
# The hostname from PAPERCLIP_PUBLIC_URL is included automatically.
PAPERCLIP_ALLOWED_HOSTNAMES=

# Bind Docker port to Tailscale IP only (recommended).
# Default is 127.0.0.1 (loopback only). Set to your Tailscale IP to allow
# tailnet access, or 0.0.0.0 if behind a reverse proxy/firewall.
PAPERCLIP_BIND_IP=0.0.0.0

# --- Secrets (REQUIRED — generate unique values) ---
# Generate each with: openssl rand -hex 32
BETTER_AUTH_SECRET=
PAPERCLIP_AGENT_JWT_SECRET=

# --- Database ---
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=
POSTGRES_DB=paperclip
