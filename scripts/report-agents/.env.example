# ============================================================
# Whales Market Report Agents — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# === REQUIRED ===

# Telegram Bot
TELEGRAM_BOT_TOKEN=           # Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=             # Chat/group ID where bot sends reports
TELEGRAM_THREAD_ID=           # (Optional) Thread ID for topic-based groups

# Whales Market Database
WHALES_DB_PATH=               # Absolute path to whales_market.db SQLite file
METABASE_SYNC_DIR=            # (Optional) Path to metabase-sync/ dir. Default: ../../metabase-sync relative to this file

# === OPTIONAL — Social Collector ===

RAPIDAPI_KEY=                 # RapidAPI key for Twitter data
SOCIAL_ACCOUNTS=              # JSON array: [{"id":"xxx","name":"WhalesMarket"}]
THRESHOLD_STRONG=50           # Tweet engagement thresholds
THRESHOLD_GOOD=20
THRESHOLD_MODERATE=5

# === OPTIONAL — GA4 Analytics ===

GA4_PROPERTY_ID=              # Google Analytics 4 property ID
GA4_SERVICE_ACCOUNT_JSON=     # GA4 service account JSON (inline)
GA4_SERVICE_ACCOUNT_JSON_PATH= # OR path to GA4 service account JSON file

# === OPTIONAL — Paperclip Integration ===

PAPERCLIP_API_URL=            # Paperclip API base URL
PAPERCLIP_API_KEY=            # Paperclip API key
PAPERCLIP_COMPANY_ID=         # Paperclip company ID

# === OPTIONAL — AI ===

ANTHROPIC_API_KEY=            # Only needed for social-collector AI summary
