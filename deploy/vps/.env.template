# Kaizai Workforce — VPS deployment environment variables
# Copy to .env and fill in values
#
# This stack runs alongside the trading platform on app-01.
# PostgreSQL is on db-01 (private VLAN).
# Caddy is managed by the trading platform stack — add build.kaizai.co route there.

# ── Database (db-01 via private VLAN) ──
DB_PRIVATE_IP=10.0.0.2
WORKFORCE_DB_PASSWORD=
LG_DB_PASSWORD=

# ── Anthropic ──
ANTHROPIC_API_KEY=

# ── GitHub App ──
GITHUB_APP_ID=2914378
GITHUB_APP_KEY_PATH=/opt/workforce/secrets/github-app.pem

# ── Slack ──
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── LangSmith ──
LANGSMITH_API_KEY=lsv2_pt_...

# ── Notes ──
# Caddy config: Add the following to the trading platform's Caddyfile
# (deploy/vps/caddy/Caddyfile in the trading-agent repo):
#
#   build.kaizai.co {
#       reverse_proxy 127.0.0.1:3100
#   }
#
# The workforce-control container binds to 127.0.0.1:3100,
# and Caddy (running in the trading platform stack) proxies to it.
